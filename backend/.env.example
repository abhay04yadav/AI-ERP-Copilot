# App connection — non-superuser app_user role, subject to RLS.
DATABASE_URL=postgresql+psycopg://app_user:CHANGE_ME@localhost:55432/erp_copilot

# Migrations connection — privileged/owner role, can run DDL/GRANT/RLS setup.
# Falls back to DATABASE_URL if unset (not recommended outside local dev).
MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:55432/erp_copilot

# Password the bootstrap migration assigns to app_user (read from env, never hardcoded).
APP_DB_PASSWORD=CHANGE_ME

JWT_SECRET_KEY=CHANGE_ME

# Comma-separated origins allowed to call the API via CORS (Phase 3 §A.1).
FRONTEND_ORIGINS=http://localhost:5173
